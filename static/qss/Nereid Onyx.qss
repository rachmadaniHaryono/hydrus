  border: 1px solid #18191B;
  border-radius: 10px; }

QWidget#HydrusMediaList {
  qproperty-hmrp_background: #000;
  qproperty-hmrp_thumbnail_local_background_normal: #111113;
  qproperty-hmrp_thumbnail_local_border_normal: #000;
  qproperty-hmrp_thumbnail_local_background_selected: #272A2D;
  qproperty-hmrp_thumbnail_local_border_selected: #1FD8A4; }
  QWidget#HydrusMediaList QScrollBar {
    background: #000;
    border: 1px solid #000; }
    QWidget#HydrusMediaList QScrollBar:horizontal {
      height: 12px;
      padding: 0 24px; }
    QWidget#HydrusMediaList QScrollBar:vertical {
      width: 12px;
      padding: 24px 0; }
    QWidget#HydrusMediaList QScrollBar::add-line, QWidget#HydrusMediaList QScrollBar::sub-line {
      subcontrol-origin: border;
      height: 12px;
      width: 12px;
      border: 1px solid #000; }
    QWidget#HydrusMediaList QScrollBar::add-line:vertical {
      subcontrol-position: bottom;
      image: url("static/qss/nereid/dark/caret-down");
      padding-bottom: 6px; }
    QWidget#HydrusMediaList QScrollBar::add-line:horizontal {
      subcontrol-position: right;
      image: url("static/qss/nereid/dark/caret-right");
      padding-right: 6px; }
    QWidget#HydrusMediaList QScrollBar::sub-line:vertical {
      subcontrol-position: top;
      image: url("static/qss/nereid/dark/caret-up");
      padding-top: 6px; }
    QWidget#HydrusMediaList QScrollBar::sub-line:horizontal {
      subcontrol-position: left;
      image: url("static/qss/nereid/dark/caret-left");
      padding-left: 6px; }
    QWidget#HydrusMediaList QScrollBar::handle {
      background: #272A2D;
      border-radius: 2px;
      margin: 3px; }
      QWidget#HydrusMediaList QScrollBar::handle:horizontal {
        min-width: 48px; }
      QWidget#HydrusMediaList QScrollBar::handle:vertical {
        min-height: 48px; }
      QWidget#HydrusMediaList QScrollBar::handle:hover, QWidget#HydrusMediaList QScrollBar::handle:pressed {
        margin: 0;
        border: 1px solid #212225;
        border-radius: 5px; }
        QWidget#HydrusMediaList QScrollBar::handle:hover:vertical, QWidget#HydrusMediaList QScrollBar::handle:pressed:vertical {
          background: qlineargradient(x1: 0.0, y1: 0.0, x2: 1.0, y2: 0.0, stop: 0.3 rgba(46, 49, 53, 100%), stop: 0.55 rgba(33, 34, 37, 100%), stop: 0.6 rgba(33, 34, 37, 100%), stop: 0.95 rgba(46, 49, 53, 100%)); }
        QWidget#HydrusMediaList QScrollBar::handle:hover:horizontal, QWidget#HydrusMediaList QScrollBar::handle:pressed:horizontal {
          background: qlineargradient(x1: 0.0, y1: 0.0, x2: 0.0, y2: 1.0, stop: 0.3 rgba(46, 49, 53, 100%), stop: 0.55 rgba(33, 34, 37, 100%), stop: 0.6 rgba(33, 34, 37, 100%), stop: 0.95 rgba(46, 49, 53, 100%)); }
    QWidget#HydrusMediaList QScrollBar::add-page, QWidget#HydrusMediaList QScrollBar::sub-page {
      background: #000; }

